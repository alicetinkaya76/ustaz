      ],
      "word_count": 3
    },
    {
      "number": 6,
      "text_ar": "سَنُقۡرِئُكَ فَلَا تَنسَىٰٓ",
      "text_tr_diyanet": "Sana Kuran'ı Biz okutacağız ve asla unutmayacaksın;",
      "text_tr_vakfi": "Sana (Kur an'ı) okutacağız; sen hiç unutmayacaksın.",
      "text_tr_yazir": "Bundan böyle sana Kur'ân'ı okutacağız da unutmayacaksın.",
