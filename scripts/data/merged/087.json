  "ayahs": [
    {
      "number": 1,
      "text_ar": "سَبِّحِ ٱسۡمَ رَبِّكَ ٱلۡأَعۡلَى",
      "text_tr_diyanet": "Yüce Rabbinin adını tesbih et.",
      "text_tr_vakfi": "Yüce Rabbinin adını,",
      "text_tr_yazir": "Rabbinin yüce adını tesbih et.",
      "transliteration": "sebbiḥi-sme rabbike-l'a`lâ.",
      "words_ar": [
        "سَبِّحِ",
        "ٱسۡمَ",
        "رَبِّكَ",
        "ٱلۡأَعۡلَى"
      ],
      "words_translit": [
        "sebbiḥi-sme",
        "rabbike-l'a`lâ."
      ],
      "word_count": 4
    },
    {
      "number": 2,
      "text_ar": "ٱلَّذِي خَلَقَ فَسَوَّىٰ",
      "text_tr_diyanet": "O, yaratıp şekil vermiştir.",
      "text_tr_vakfi": "Yaratıp düzene koyan,",
      "text_tr_yazir": "Yaratıp düzene koyan O'dur.",
      "transliteration": "elleẕî ḫaleḳa fesevvâ.",
      "words_ar": [
        "ٱلَّذِي",
        "خَلَقَ",
        "فَسَوَّىٰ"
      ],
      "words_translit": [
        "elleẕî",
        "ḫaleḳa",
        "fesevvâ."
      ],
      "word_count": 3
    },
    {
      "number": 3,
      "text_ar": "وَٱلَّذِي قَدَّرَ فَهَدَىٰ",
      "text_tr_diyanet": "O, her şeyi ölçüyle yapıp doğru yolu göstermiştir.",
      "text_tr_vakfi": "Takdir edip yol gösteren,",
      "text_tr_yazir": "Takdir edip hidayeti gösteren O'dur.",
      "transliteration": "velleẕî ḳaddera fehedâ.",
      "words_ar": [
        "وَٱلَّذِي",
        "قَدَّرَ",
        "فَهَدَىٰ"
      ],
      "words_translit": [
        "velleẕî",
        "ḳaddera",
        "fehedâ."
      ],
      "word_count": 3
    },
    {
      "number": 4,
      "text_ar": "وَٱلَّذِيٓ أَخۡرَجَ ٱلۡمَرۡعَىٰ",
      "text_tr_diyanet": "O, yeşillikler bitirmiştir.",
      "text_tr_vakfi": "(Topraktan) yeşil otu çıkaran,",
      "text_tr_yazir": "Otlağı çıkaran,",
      "transliteration": "velleẕî aḫrace-lmer`â.",
      "words_ar": [
        "وَٱلَّذِيٓ",
        "أَخۡرَجَ",
        "ٱلۡمَرۡعَىٰ"
      ],
