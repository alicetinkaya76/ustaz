    {
      "number": 11,
      "text_ar": "كَذَّبَتۡ ثَمُودُ بِطَغۡوَىٰهَآ",
      "text_tr_diyanet": "Semud milleti, içlerinden en azgını ileri atılınca, azgınlığı yüzünden peygamberleri yalanladı.",
      "text_tr_vakfi": "Semud kavmi azgınlığı yüzünden (Allah'ın elçisini) yalanladı.",
      "text_tr_yazir": "Semud, azgınlığıyla Hakk'ı yalanladı,",
      "transliteration": "keẕẕebet ŝemûdü biṭagvâhâ.",
