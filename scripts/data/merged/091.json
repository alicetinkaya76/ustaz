      "text_tr_vakfi": "Onu açığa çıkarttığında gündüze,",
      "text_tr_yazir": "Güneş'i açıp ortaya çıkaran gündüze,",
      "transliteration": "vennehâri iẕâ cellâhâ.",
      "words_ar": [
