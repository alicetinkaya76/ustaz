    {
      "number": 4,
      "text_ar": "وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ",
      "text_tr_diyanet": "Doğurması yaklaşmış develer başıboş bırakıldığı zaman;",
      "text_tr_vakfi": "Gebe develer salıverildiğinde,",
      "text_tr_yazir": "Kıyılmaz mallar bırakıldığında,",
