    {
      "number": 8,
      "text_ar": "وَإِذَا ٱلۡمَوۡءُۥدَةُ سُئِلَتۡ",
      "text_tr_diyanet": "Kız çocuğun hangi suçtan ötürü öldürüldüğü kendisine sorulduğu zaman;",
      "text_tr_vakfi": "Diri diri toprağa gömülen kıza, sorulduğunda,",
      "text_tr_yazir": "Diri diri toprağa gömülen kıza sorulduğunda,",
      "transliteration": "veiẕe-lmev'ûdetü süilet.",
      "words_ar": [
