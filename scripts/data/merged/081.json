      "words_translit": [
        "veiẕe-lmev'ûdetü",
        "süilet."
      ],
      "word_count": 3
    },
    {
      "number": 9,
      "text_ar": "بِأَيِّ ذَنۢبٖ قُتِلَتۡ",
      "text_tr_diyanet": "Kız çocuğun hangi suçtan ötürü öldürüldüğü kendisine sorulduğu zaman;",
      "text_tr_vakfi": "\"Hangi günah sebebiyle öldürüldü? diye.",
      "text_tr_yazir": "\"Hangi günahtan dolayı öldürüldü?\" diye.",
      "transliteration": "bieyyi ẕembin ḳutilet.",
      "words_ar": [
