    {
      "number": 2,
      "text_ar": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ",
      "text_tr_diyanet": "Yıldızlar düşüp, söndüğü zaman;",
      "text_tr_vakfi": "Yıldızlar (kararıp) döküldüğünde,",
      "text_tr_yazir": "Yıldızlar bulandığında,",
      "transliteration": "veiẕe-nnücûmü-nkederat.",
