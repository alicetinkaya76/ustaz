              "root": null,
              "pos": "harf",
              "meaning_tr": "ve ne",
              "irab": "Vâv atıf harfi, mâ istifhâm edatı mübtedâ konumunda.",
              "irab_short": "istifhâm, mübtedâ",
              "turkish_bridge": null,
              "balagha_note": "Tehvîl üslubu ile büyük bir şeyi tasvir etme"
