              "irab_short": "mecrûr, fî ile",
              "turkish_bridge": null,
              "balagha_note": "Mübalağa vezniyle şiddetli kırma, ezme anlamı"
            }
          ]
        },
        {
          "surah": 104,
          "ayah": 5,
          "arabic": "وَمَآ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ",
