              "meaning_tr": "hutame nedir",
              "irab": "Mâ istifhâm mübtedâ, el-hutametu müdhaf ileyh değil خبر konumunda merfû.",
              "irab_short": "haber, merfû",
              "turkish_bridge": null,
              "balagha_note": "İkinci defa zikredilerek merak uyandırma"
            }
          ]
        },
        {
          "surah": 104,
          "ayah": 6,
          "arabic": "نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ",
