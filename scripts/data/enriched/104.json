{
  "surah": 104,
  "blocks": [
    {
      "ayah_start": 1,
      "ayah_end": 9,
      "description": "Mal biriktirip insanları küçümseyenlerin cehennemdeki azabını tasvir eden kısa bir sure.",
      "verses": [
        {
          "surah": 104,
          "ayah": 1,
          "arabic": "وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ",
          "translation": "Mal toplayarak onu tekrar tekrar sayan, diliyle çekiştirip alay eden kimsenin vay haline!",
          "words": [
            {
              "arabic": "وَيۡلٞ",
              "transliteration": "veylül",
              "root": "و-ي-ل",
              "pattern": "فَعْل",
              "pos": "ism",
              "meaning_tr": "vay haline, helâket",
              "irab": "{Mübtedâ}, merfû. Hazf edilmiş müdhaf ileyhli tamlamanın müdhafı konumundadır.",
              "irab_short": "mübtedâ, merfû",
              "turkish_bridge": null,
              "balagha_note": "Tehdit ve kınama ifadesi olarak güçlü vurgu"
            },
            {
              "arabic": "لِّكُلِّ",
              "transliteration": "likülli",
              "root": "ك-ل-ل",
              "pattern": "فُعْل",
              "pos": "ism",
              "meaning_tr": "her bir için",
              "irab": "{Câr-mecrûr} takımı. Lâm harfi cer, müdhaf olan كُلّ ismi mecrûr.",
              "irab_short": "mecrûr, lâm ile",
              "turkish_bridge": "Küll, küllî bu kökten",
              "balagha_note": "Umûm ifadesiyle tüm bu tipteki insanları kapsar"
            },
            {
              "arabic": "هُمَزَةٖ",
              "transliteration": "hümezetin",
              "root": "ه-م-ز",
              "pattern": "فُعَلَة",
              "pos": "ism",
              "meaning_tr": "çok kaş göz ile alay eden",
              "irab": "{Müdhaf ileyh}, mecrûr. Küll kelimesinin müdhaf ileyhidir.",
              "irab_short": "müdhaf ileyh, mecrûr",
              "turkish_bridge": null,
              "balagha_note": "Mübalağa sîgası ile süreklilik vurgusu"
            },
            {
              "arabic": "لُّمَزَةٍ",
              "transliteration": "lümezeh",
              "root": "ل-م-ز",
              "pattern": "فُعَلَة",
              "pos": "ism",
              "meaning_tr": "çok dil ile çekiştiren",
              "irab": "{Sıfat}, mecrûr. Hümeze kelimesinin sıfatıdır.",
              "irab_short": "sıfat, mecrûr",
              "turkish_bridge": null,
              "balagha_note": "Mübalağa sîgası ve iki benzer kelimeyle âhenk (cinâs-ı nâkıs)"
            }
          ]
        },
        {
          "surah": 104,
          "ayah": 2,
          "arabic": "ٱلَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ",
          "translation": "Mal toplayıp onu tekrar tekrar sayan",
          "words": [
            {
              "arabic": "ٱلَّذِي",
              "transliteration": "ellezî",
              "root": null,
              "pos": "ism",
              "meaning_tr": "o ki, olan",
              "irab": "{Mevsûl ismi}, hümeze ve lümeze kelimelerinin sıfatıdır, mecrûr.",
              "irab_short": "mevsûl, sıfat",
              "turkish_bridge": null,
              "balagha_note": null
            },
            {
              "arabic": "جَمَعَ",
              "transliteration": "cemea",
              "root": "ج-م-ع",
              "pattern": "فَعَلَ",
              "pos": "fil",
              "meaning_tr": "topladı",
              "irab": "{Fiil-i mâzî}, I. bâb. Fâili müstetir zamirdir, ellezî'ye râci.",
              "irab_short": "mâzî, I. bâb",
              "turkish_bridge": "Cem, cemaat, mecmu bu kökten",
              "balagha_note": null
            },
            {
              "arabic": "مَالٗا",
              "transliteration": "mâlen",
              "root": "م-و-ل",
              "pattern": "فَعْل",
              "pos": "ism",
              "meaning_tr": "mal",
              "irab": "{Mef'ûl bih}, mensûb. Cemea fiilinin mef'ûlüdür.",
              "irab_short": "mef'ûl bih, mensûb",
              "turkish_bridge": "Mal bu kökten",
              "balagha_note": null
            },
            {
              "arabic": "وَعَدَّدَهُۥ",
              "transliteration": "ve addedeh",
              "root": "ع-د-د",
              "pattern": "فَعَّلَ",
              "pos": "fil",
              "meaning_tr": "ve onu saydı",
              "irab": "Vâv atıf harfi, {fiil-i mâzî} II. bâb. Sonundaki hâ zamiri mef'ûl bih olarak mâle râci.",
              "irab_short": "mâzî, II. bâb",
              "turkish_bridge": "Adet, adedî bu kökten",
              "balagha_note": "II. bâb ile tekrar tekrar sayma anlamı (mübalağa)"
            }
          ]
        },
        {
          "surah": 104,
          "ayah": 3,
          "arabic": "يَحۡسَبُ أَنَّ مَالَهُۥٓ أَخۡلَدَهُۥ",
          "translation": "Malının kendisini ölümsüz kılacağını sanır.",
          "words": [
            {
              "arabic": "يَحۡسَبُ",
              "transliteration": "yahsebü",
              "root": "ح-س-ب",
              "pattern": "يَفْعَلُ",
              "pos": "fil",
              "meaning_tr": "sanır",
              "irab": "{Fiil-i mudâri}, I. bâb. Fâili müstetir zamirdir, ellezî'ye râci.",
              "irab_short": "mudâri, I. bâb",
              "turkish_bridge": "Hesap bu kökten",
              "balagha_note": null
            },
            {
              "arabic": "أَنَّ",
              "transliteration": "enne",
              "root": null,
              "pos": "harf",
              "meaning_tr": "-i/-ı (takdir)",
              "irab": "{Hurûf-i müşebbehe bi'l-fi'l}den, ismini mensûb haberi merfû kılar.",
              "irab_short": "hurûf-i müşebbehe",
              "turkish_bridge": null,
              "balagha_note": null
            },
            {
              "arabic": "مَالَهُۥٓ",
              "transliteration": "mâlehû",
              "root": "م-و-ل",
              "pattern": "فَعْل",
              "pos": "ism",
              "meaning_tr": "onun malı",
              "irab": "{İsm-i enne}, mensûb. Sonundaki hâ zamiri müdhaf ileyh olarak ellezî'ye râci.",
              "irab_short": "ism-i enne, mensûb",
              "turkish_bridge": "Mal bu kökten",
              "balagha_note": null
            },
            {
              "arabic": "أَخۡلَدَهُۥ",
              "transliteration": "ahledehû",
              "root": "خ-ل-د",
              "pattern": "أَفْعَلَ",
              "pos": "fil",
              "meaning_tr": "onu ebedî kıldı",
              "irab": "{Fiil-i mâzî} IV. bâb, enne'nin haberi konumunda. Sonundaki hâ zamiri mef'ûl bih olarak ellezî'ye râci.",
              "irab_short": "mâzî, IV. bâb, haber",
              "turkish_bridge": "Hulûd, muhlid bu kökten",
              "balagha_note": "İroni: malın ölümsüzlük verebileceği zannının saçmalığı"
            }
          ]
        },
        {
          "surah": 104,
          "ayah": 4,
          "arabic": "كَلَّاۖ لَيُنۢبَذَنَّ فِي ٱلۡحُطَمَةِ",
